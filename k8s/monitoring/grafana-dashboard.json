{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "Prometheus",
        "enable": true,
        "expr": "changes(rl_autoscaler_lifecycle_state[1m]) > 0",
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Lifecycle Transitions",
        "step": "60s",
        "titleFormat": "State Change"
      }
    ]
  },
  "description": "AWARE-inspired RL Autoscaler — HPA vs RL comparison dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{namespace=\"rl-autoscaler\",deployment=\"workload-app\"}",
          "legendFormat": "Ready Replicas",
          "refId": "A"
        }
      ],
      "title": "Replica Count Over Time",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "tooltip": { "mode": "multi" },
        "thresholdsStyle": { "mode": "line" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"workload-app\"}[1m])) by (le)) * 1000",
          "legendFormat": "p95 Latency (ms)",
          "refId": "A"
        },
        {
          "expr": "500",
          "legendFormat": "SLO Target (500ms)",
          "refId": "B"
        }
      ],
      "title": "p95 Request Latency vs SLO",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"rl-autoscaler\",container=\"workload-app\"}[1m]))",
          "legendFormat": "CPU Usage (cores)",
          "refId": "A"
        }
      ],
      "title": "CPU Utilisation",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"workload-app\"}[1m]))",
          "legendFormat": "Request Rate (req/s)",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "100 * sum(rate(http_request_duration_seconds_count{job=\"workload-app\"}[5m]) unless rate(http_request_duration_seconds_bucket{le=\"0.5\",job=\"workload-app\"}[5m])) / sum(rate(http_request_duration_seconds_count{job=\"workload-app\"}[5m]))",
          "legendFormat": "SLO Violation %",
          "refId": "A"
        }
      ],
      "title": "SLO Violation Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["mean"] } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"workload-app\"}[5m]))",
          "legendFormat": "Avg RPS",
          "refId": "A"
        }
      ],
      "title": "Avg Request Rate (5m)",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["kubernetes", "autoscaler", "rl", "aware"],
  "title": "AWARE RL Autoscaler",
  "uid": "aware-rl-autoscaler",
  "version": 1
}
